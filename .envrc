# Automatically load Nix shell environment
use nix

# Load .env file if it exists
dotenv_if_exists

# Export project-specific environment variables
export PROJECT_NAME="ai-presentation-generator"
export PROJECT_VERSION="1.0.0"

# Development settings
export NODE_ENV="development"
export VITE_API_URL="http://localhost:8000"

# Optional: Add local bin to PATH
PATH_add node_modules/.bin

# Welcome message
echo "🚀 Loaded AI Presentation Generator environment"
echo "📁 Project root: $PWD"
