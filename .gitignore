yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn/

# Python
venv/
env/
ENV/
*.pyc
__pycache__/
*.py[cod]
*$py.class
.Python
pip-log.txt
pip-delete-this-directory.txt

