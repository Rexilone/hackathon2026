# AI Генератор Презентаций - Environment Variables
# Скопируйте этот файл в .env и заполните значения

# ============================================
# LLM API Keys
# ============================================

# Anthropic Claude (рекомендуется)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI GPT (альтернатива)
OPENAI_API_KEY=sk-xxxxx

# YandexGPT (для российских deployments)
YANDEX_GPT_API_KEY=xxxxx
YANDEX_FOLDER_ID=xxxxx

# GigaChat (Сбер)
GIGACHAT_API_KEY=xxxxx

# ============================================
# Image Generation APIs
# ============================================

# Kandinsky (Sber AI)
KANDINSKY_API_KEY=xxxxx
KANDINSKY_SECRET=xxxxx

# Stability AI
STABILITY_API_KEY=sk-xxxxx

# DALL-E (OpenAI)
# Использует тот же OPENAI_API_KEY

# Midjourney (если доступно через API)
MIDJOURNEY_API_KEY=xxxxx

# ============================================
# Application Settings
# ============================================

# Environment
NODE_ENV=development
DEBUG=true

# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# API Base URL
VITE_API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# File Upload Settings
# ============================================

# Maximum file size (in bytes) - 10MB default
MAX_FILE_SIZE=10485760

# Allowed file extensions
ALLOWED_EXTENSIONS=.pdf,.docx,.txt

# Upload directory
UPLOAD_FOLDER=/tmp/uploads
OUTPUT_FOLDER=/tmp/output

# ============================================
# Redis Settings (для кеширования и очередей)
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Celery Settings (для асинхронных задач)
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# Database (если используется)
# ============================================

DATABASE_URL=postgresql://user:password@localhost:5432/presentations
DATABASE_POOL_SIZE=10

# ============================================
# Security
# ============================================

# Secret key for JWT tokens
SECRET_KEY=your-secret-key-change-in-production

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Password hashing
BCRYPT_ROUNDS=12

# ============================================
# Monitoring & Logging
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FILE=app.log

# Sentry (error tracking)
SENTRY_DSN=

# Prometheus (metrics)
PROMETHEUS_PORT=9090

# ============================================
# Rate Limiting
# ============================================

# Requests per hour per IP
RATE_LIMIT_PER_HOUR=100

# Requests per day per user
RATE_LIMIT_PER_DAY=1000

# ============================================
# Presentation Settings
# ============================================

# Default settings
DEFAULT_TONE=official
DEFAULT_SLIDE_COUNT=10
DEFAULT_COLOR_SCHEME=gradient
DEFAULT_INCLUDE_IMAGES=true

# Limits
MIN_SLIDE_COUNT=5
MAX_SLIDE_COUNT=20

# ============================================
# Feature Flags
# ============================================

ENABLE_AI_IMAGES=true
ENABLE_PDF_EXPORT=true
ENABLE_ANALYTICS=false
ENABLE_COLLABORATION=false

# ============================================
# External Services
# ============================================

# Email service (для уведомлений)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@rostelecom-ai.ru

# Cloud storage (для backup)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=presentations-backup
AWS_REGION=eu-central-1

# ============================================
# Development & Testing
# ============================================

# Skip API calls in development (use mocks)
USE_MOCK_LLM=false
USE_MOCK_IMAGES=false

# Test mode
TEST_MODE=false

# ============================================
# Production Settings
# ============================================

# Domain
DOMAIN=rostelecom-ai.ru
PROTOCOL=https

# SSL
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# Workers
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker

# Timeouts
REQUEST_TIMEOUT=300
KEEPALIVE_TIMEOUT=5

# ============================================
# Analytics & Tracking
# ============================================

# Google Analytics
GA_TRACKING_ID=

# Yandex Metrika
YM_COUNTER_ID=

# ============================================
# Rostelecom Specific
# ============================================

# Branding
BRAND_NAME="Ростелеком"
BRAND_COLORS_PRIMARY=#0019B5
BRAND_COLORS_SECONDARY=#FF4F12
BRAND_COLORS_ACCENT=#7700C7

# Legal
COMPANY_NAME="ПАО Ростелеком"
COMPANY_INN=7707049388
PRIVACY_POLICY_URL=https://rostelecom.ru/privacy
TERMS_OF_SERVICE_URL=https://rostelecom.ru/terms

# ============================================
# Notes
# ============================================

# Для получения API ключей:
# - Anthropic Claude: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/
# - Kandinsky: https://fusionbrain.ai/
# - Stability AI: https://platform.stability.ai/

# Не коммитьте файл .env в git!
# Добавьте .env в .gitignore
